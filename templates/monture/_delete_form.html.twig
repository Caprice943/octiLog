<form method="post" action="{{ path('app_monture_delete', {'id': monture.id}) }}" onsubmit="return confirm('Supprimer définitivement cette monture ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ monture.id) }}">
    <button class="rounded-lg border border-red-200 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50">Supprimer</button>
</form>
